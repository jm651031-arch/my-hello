<!DOCTYPE html>

<html lang="zh-TW">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>明曜晶光顯科技 | LCD顯示方案與光學膜材</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700&family=Noto+Sans+TC:wght@300;400;500&family=Barlow+Condensed:wght@300;400;600;700&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #060e1c;
  --navy: #091525;
  --panel: #0c1e32;
  --cyan: #00d4ff;
  --blue: #0a84ff;
  --gold: #c8a84b;
  --white: #e8f0f8;
  --muted: #4a6a8a;
  --border: rgba(0,212,255,0.12);
  --bar-h: 56px;
  --nav-h: 62px;
}
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
html{scroll-behavior:smooth;}
body{
  background:var(--bg);
  color:var(--white);
  font-family:'Noto Sans TC',sans-serif;
  font-weight:300;
  overflow-x:hidden;
  padding-bottom:var(--bar-h);
}
body::before{
  content:'';
  position:fixed;inset:0;
  background-image:
    linear-gradient(rgba(0,212,255,0.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,212,255,0.025) 1px,transparent 1px);
  background-size:48px 48px;
  pointer-events:none;z-index:0;
}

/* ── NAV ── */
nav{
position:fixed;top:0;left:0;right:0;z-index:200;
height:var(–nav-h);
display:flex;align-items:center;justify-content:space-between;
padding:0 18px;
background:rgba(6,14,28,0.96);
backdrop-filter:blur(12px);
border-bottom:1px solid var(–border);
}
.nav-brand{display:flex;flex-direction:column;gap:1px;}
.nav-brand-cn{
font-family:‘Noto Serif TC’,serif;
font-size:16px;font-weight:700;
letter-spacing:3px;color:var(–white);
}
.nav-brand-en{
font-family:‘Barlow Condensed’,sans-serif;
font-size:9px;letter-spacing:3px;
color:var(–cyan);text-transform:uppercase;
}
.hamburger{
width:40px;height:40px;
border:1px solid var(–border);
border-radius:50%;
display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;
cursor:pointer;background:transparent;
transition:border-color .3s;
}
.hamburger:hover{border-color:var(–cyan);}
.hamburger span{
display:block;width:18px;height:1.5px;
background:var(–white);
transition:all .3s;
transform-origin:center;
}
.hamburger.open span:nth-child(1){transform:translateY(6.5px) rotate(45deg);}
.hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0);}
.hamburger.open span:nth-child(3){transform:translateY(-6.5px) rotate(-45deg);}

/* ── DRAWER MENU ── */
.drawer{
position:fixed;top:var(–nav-h);left:0;right:0;bottom:var(–bar-h);
z-index:190;
background:rgba(6,14,28,0.98);
backdrop-filter:blur(16px);
transform:translateX(100%);
transition:transform .35s cubic-bezier(.4,0,.2,1);
overflow-y:auto;
}
.drawer.open{transform:translateX(0);}
.drawer-menu{list-style:none;padding:8px 0;}
.drawer-item{border-bottom:1px solid var(–border);}
.drawer-btn{
width:100%;display:flex;align-items:center;justify-content:space-between;
padding:18px 24px;
background:none;border:none;color:var(–white);
font-family:‘Noto Sans TC’,sans-serif;font-size:15px;font-weight:400;
cursor:pointer;text-align:left;
transition:background .2s;
}
.drawer-btn:hover{background:rgba(0,212,255,0.05);}
.drawer-btn .icon{
font-size:18px;color:var(–muted);
transition:transform .3s,color .3s;
}
.drawer-btn.active .icon{transform:rotate(45deg);color:var(–cyan);}
.sub-menu{
list-style:none;
max-height:0;overflow:hidden;
transition:max-height .35s ease;
background:rgba(9,21,37,0.6);
}
.sub-menu.open{max-height:400px;}
.sub-menu li a{
display:block;padding:13px 24px 13px 40px;
font-size:13px;color:var(–muted);
text-decoration:none;
border-bottom:1px solid rgba(0,212,255,0.04);
transition:color .2s,padding-left .2s;
}
.sub-menu li a:hover{color:var(–cyan);padding-left:48px;}

/* ── HERO ── */
.hero{
position:relative;min-height:100vh;
display:flex;flex-direction:column;justify-content:center;
padding:calc(var(–nav-h) + 40px) 20px 60px;
overflow:hidden;
}
.hero-orb{
position:absolute;border-radius:50%;filter:blur(70px);pointer-events:none;
}
.orb1{width:300px;height:300px;top:-60px;right:-60px;
background:radial-gradient(circle,rgba(0,212,255,0.15) 0%,transparent 70%);
animation:pulse 8s ease-in-out infinite;}
.orb2{width:250px;height:250px;bottom:80px;left:-40px;
background:radial-gradient(circle,rgba(10,132,255,0.12) 0%,transparent 70%);
animation:pulse 12s ease-in-out infinite reverse;}
@keyframes pulse{
0%,100%{opacity:.6;transform:scale(1);}
50%{opacity:1;transform:scale(1.15);}
}
.hero-tag{
font-family:‘Barlow Condensed’,sans-serif;
font-size:10px;letter-spacing:4px;
color:var(–cyan);text-transform:uppercase;
margin-bottom:16px;
display:flex;align-items:center;gap:10px;
}
.hero-tag::before{content:’’;display:inline-block;width:30px;height:1px;background:var(–cyan);}
.hero-title{
font-family:‘Noto Serif TC’,serif;
font-size:clamp(32px,9vw,56px);
font-weight:700;line-height:1.2;
margin-bottom:10px;letter-spacing:.04em;
position:relative;z-index:1;
}
.hero-title .hl{
background:linear-gradient(135deg,var(–cyan),var(–blue));
-webkit-background-clip:text;-webkit-text-fill-color:transparent;
}
.hero-sub{
font-family:‘Barlow Condensed’,sans-serif;
font-size:13px;letter-spacing:3px;
color:var(–muted);margin-bottom:20px;
text-transform:uppercase;position:relative;z-index:1;
}
.hero-desc{
font-size:14px;line-height:2;
color:rgba(168,196,224,0.8);
margin-bottom:32px;
position:relative;z-index:1;
}
.hero-stats{
display:flex;gap:28px;margin-bottom:32px;
position:relative;z-index:1;
}
.stat{text-align:center;}
.stat-n{
font-family:‘Barlow Condensed’,sans-serif;
font-size:32px;font-weight:600;color:var(–white);
line-height:1;
}
.stat-n small{font-size:18px;color:var(–cyan);}
.stat-l{font-size:10px;letter-spacing:1.5px;color:var(–muted);text-transform:uppercase;margin-top:3px;}
.hero-cta{
display:inline-flex;align-items:center;gap:10px;
padding:14px 28px;
border:1px solid var(–cyan);
color:var(–cyan);text-decoration:none;
font-family:‘Barlow Condensed’,sans-serif;
font-size:12px;letter-spacing:3px;text-transform:uppercase;
position:relative;z-index:1;overflow:hidden;
transition:color .3s;
}
.hero-cta::before{
content:’’;position:absolute;inset:0;
background:var(–cyan);transform:translateX(-100%);
transition:transform .3s;z-index:-1;
}
.hero-cta:active{color:var(–bg);}
.hero-cta:active::before{transform:translateX(0);}

/* ── SECTIONS ── */
section{position:relative;z-index:1;padding:60px 20px;}
.sec-tag{
font-family:‘Barlow Condensed’,sans-serif;
font-size:10px;letter-spacing:4px;color:var(–cyan);
text-transform:uppercase;margin-bottom:8px;
display:flex;align-items:center;gap:10px;
}
.sec-tag::before{content:’’;display:inline-block;width:24px;height:1px;background:var(–cyan);}
.sec-title{
font-family:‘Noto Serif TC’,serif;
font-size:clamp(22px,5vw,32px);font-weight:700;
letter-spacing:.04em;margin-bottom:32px;
}

/* ── ABOUT ── */
.about-desc{font-size:14px;line-height:2.2;color:rgba(168,196,224,0.8);margin-bottom:24px;}
.info-cards{display:flex;flex-direction:column;gap:12px;}
.icard{
padding:16px 20px;
border-left:2px solid var(–cyan);
background:rgba(0,212,255,0.04);
}
.icard-label{font-family:‘Barlow Condensed’,sans-serif;font-size:9px;letter-spacing:2px;color:var(–muted);text-transform:uppercase;margin-bottom:5px;}
.icard-val{font-size:13px;color:var(–white);line-height:1.6;}

/* ── BUSINESS ── */
.biz-cards{display:flex;flex-direction:column;gap:2px;}
.biz-card{
background:var(–navy);
padding:32px 24px;
border-bottom:2px solid transparent;
transition:border-color .3s;
position:relative;overflow:hidden;
}
.biz-card::before{
content:’’;position:absolute;bottom:0;left:0;right:0;height:2px;
background:linear-gradient(to right,var(–cyan),transparent);
transform:scaleX(0);transition:transform .4s;transform-origin:left;
}
.biz-card:hover::before{transform:scaleX(1);}
.biz-num{
font-family:‘Barlow Condensed’,sans-serif;font-size:52px;font-weight:700;
color:rgba(10,132,255,0.08);line-height:1;margin-bottom:12px;
}
.biz-title{font-family:‘Noto Serif TC’,serif;font-size:18px;margin-bottom:16px;}
.biz-list{list-style:none;}
.biz-list li{
font-size:13px;color:var(–muted);line-height:1.8;
padding-left:14px;position:relative;
}
.biz-list li::before{content:’—’;position:absolute;left:0;color:var(–cyan);}

/* ── APPS ── */
.app-grid{display:flex;flex-direction:column;gap:16px;}
.app-card{
border:1px solid var(–border);
padding:28px 20px;
background:linear-gradient(135deg,var(–navy),transparent);
display:flex;gap:16px;align-items:flex-start;
transition:border-color .3s;
}
.app-card:active{border-color:rgba(0,212,255,0.4);}
.app-icon{font-size:28px;flex-shrink:0;margin-top:2px;}
.app-title{font-family:‘Noto Serif TC’,serif;font-size:16px;margin-bottom:8px;}
.app-desc{font-size:12px;color:var(–muted);line-height:1.9;}

/* ── FILMS ── */
.film-list{display:flex;flex-direction:column;gap:16px;}
.film-card{
background:var(–panel);border:1px solid var(–border);
padding:20px;display:flex;gap:16px;align-items:flex-start;
transition:border-color .3s;
}
.film-card:active{border-color:var(–cyan);}
.film-dot{
width:44px;height:44px;border-radius:50%;flex-shrink:0;
background:linear-gradient(135deg,var(–cyan),var(–blue));
display:flex;align-items:center;justify-content:center;font-size:18px;
}
.film-name{color:var(–cyan);font-family:‘Noto Serif TC’,serif;font-size:15px;margin-bottom:6px;}
.film-desc{font-size:12px;color:var(–muted);line-height:1.8;margin-bottom:10px;}
.film-tags{display:flex;flex-wrap:wrap;gap:6px;}
.ftag{
font-family:‘Barlow Condensed’,sans-serif;font-size:9px;letter-spacing:1.5px;
padding:3px 8px;border:1px solid var(–blue);color:var(–blue);text-transform:uppercase;
}

/* ── CASES ── */
.cases-section{background:var(–navy);}
.case-search{margin-bottom:24px;}
.search-bar{
width:100%;padding:12px 16px;
background:var(–panel);border:1px solid var(–border);
color:var(–white);font-family:‘Noto Sans TC’,sans-serif;font-size:14px;
outline:none;
transition:border-color .3s;
}
.search-bar:focus{border-color:var(–cyan);}
.search-bar::placeholder{color:var(–muted);}
.case-tabs{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:24px;}
.case-tab{
padding:6px 16px;border:1px solid var(–border);
background:none;color:var(–muted);
font-family:‘Noto Sans TC’,sans-serif;font-size:12px;
cursor:pointer;transition:all .2s;
}
.case-tab.active,.case-tab:hover{border-color:var(–cyan);color:var(–cyan);}
.case-grid{display:flex;flex-direction:column;gap:16px;}
.case-card{
border:1px solid var(–border);
background:var(–panel);
overflow:hidden;
transition:border-color .3s;
}
.case-card:active{border-color:var(–cyan);}
.case-img{
width:100%;height:160px;
background:linear-gradient(135deg,var(–navy),var(–panel));
display:flex;align-items:center;justify-content:center;
font-size:40px;border-bottom:1px solid var(–border);
position:relative;overflow:hidden;
}
.case-img::after{
content:’’;position:absolute;inset:0;
background:linear-gradient(135deg,rgba(0,212,255,0.06),transparent);
}
.case-body{padding:16px;}
.case-cat{
font-family:‘Barlow Condensed’,sans-serif;font-size:9px;letter-spacing:2px;
color:var(–cyan);text-transform:uppercase;margin-bottom:6px;
}
.case-name{font-family:‘Noto Serif TC’,serif;font-size:15px;margin-bottom:6px;}
.case-desc{font-size:12px;color:var(–muted);line-height:1.8;}

/* ── PROCESS ── */
.steps{display:flex;flex-direction:column;gap:0;}
.step-item{
display:flex;gap:16px;
padding:20px 0;
border-bottom:1px solid var(–border);
position:relative;
}
.step-item:last-child{border-bottom:none;}
.step-circle{
width:52px;height:52px;border-radius:50%;border:1px solid var(–cyan);
display:flex;flex-direction:column;align-items:center;justify-content:center;
flex-shrink:0;background:var(–navy);
}
.step-n{font-family:‘Barlow Condensed’,sans-serif;font-size:16px;font-weight:600;color:var(–cyan);line-height:1;}
.step-s{font-family:‘Barlow Condensed’,sans-serif;font-size:8px;letter-spacing:1px;color:var(–muted);}
.step-content{}
.step-title{font-family:‘Noto Serif TC’,serif;font-size:15px;margin-bottom:5px;}
.step-desc{font-size:12px;color:var(–muted);line-height:1.8;}

/* ── TEAM ── */
.team-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.team-card{
border:1px solid var(–border);padding:20px 14px;text-align:center;
background:rgba(0,212,255,0.03);
transition:border-color .3s;
}
.team-card:active{border-color:rgba(0,212,255,0.4);}
.team-av{
width:52px;height:52px;border-radius:50%;
border:1.5px solid var(–cyan);
display:flex;align-items:center;justify-content:center;
font-family:‘Barlow Condensed’,sans-serif;font-size:20px;color:var(–cyan);
margin:0 auto 12px;background:rgba(0,212,255,0.06);
}
.team-name{font-family:‘Noto Serif TC’,serif;font-size:14px;margin-bottom:4px;}
.team-role{font-family:‘Barlow Condensed’,sans-serif;font-size:9px;letter-spacing:2px;color:var(–cyan);text-transform:uppercase;margin-bottom:8px;}
.team-exp{font-size:11px;color:var(–muted);line-height:1.7;}

/* ── ADV ── */
.adv-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.adv-card{
background:var(–navy);padding:24px 16px;text-align:center;
border:1px solid var(–border);
transition:border-color .3s;
}
.adv-card:active{border-color:var(–cyan);}
.adv-icon{font-size:24px;margin-bottom:10px;}
.adv-title{font-family:‘Noto Serif TC’,serif;font-size:13px;color:var(–cyan);margin-bottom:8px;}
.adv-desc{font-size:11px;color:var(–muted);line-height:1.8;}
.adv-full{grid-column:1/-1;}

/* ── CLIENTS ── */
.clients-section{background:var(–navy);}
.client-group{margin-bottom:28px;}
.client-group-title{
font-family:‘Barlow Condensed’,sans-serif;font-size:10px;letter-spacing:3px;
color:var(–cyan);text-transform:uppercase;margin-bottom:12px;
padding-bottom:8px;border-bottom:1px solid var(–border);
}
.client-chips{display:flex;flex-wrap:wrap;gap:8px;}
.chip{
padding:6px 14px;border:1px solid var(–border);
font-size:12px;color:var(–muted);
transition:all .2s;
}
.chip:hover{border-color:var(–cyan);color:var(–cyan);}

/* ── VISION ── */
.vision-list{display:flex;flex-direction:column;gap:16px;}
.vision-card{
border:1px solid var(–border);padding:24px 20px;
position:relative;overflow:hidden;
}
.vision-bg{
position:absolute;top:-16px;right:12px;
font-family:‘Barlow Condensed’,sans-serif;font-size:72px;font-weight:700;
color:rgba(10,132,255,0.04);pointer-events:none;line-height:1;
}
.vision-period{font-family:‘Barlow Condensed’,sans-serif;font-size:10px;letter-spacing:3px;color:var(–gold);text-transform:uppercase;margin-bottom:8px;}
.vision-head{font-family:‘Noto Serif TC’,serif;font-size:16px;margin-bottom:14px;}
.vision-items{list-style:none;}
.vision-items li{font-size:12px;color:var(–muted);line-height:1.9;padding-left:14px;position:relative;margin-bottom:4px;}
.vision-items li::before{content:‘▸’;position:absolute;left:0;color:var(–gold);font-size:9px;top:2px;}

/* ── CONTACT ── */
.contact-section{background:linear-gradient(135deg,var(–navy),var(–bg));border-top:1px solid var(–border);}
.contact-headline{font-family:‘Noto Serif TC’,serif;font-size:clamp(20px,5vw,28px);line-height:1.5;margin-bottom:12px;}
.contact-sub{font-size:13px;color:var(–muted);line-height:2;margin-bottom:32px;}
.contact-items{display:flex;flex-direction:column;gap:20px;}
.contact-item{display:flex;gap:16px;align-items:flex-start;}
.contact-icon{
width:40px;height:40px;border:1px solid var(–cyan);flex-shrink:0;
display:flex;align-items:center;justify-content:center;font-size:16px;color:var(–cyan);
}
.contact-label{font-family:‘Barlow Condensed’,sans-serif;font-size:9px;letter-spacing:2px;color:var(–muted);text-transform:uppercase;margin-bottom:4px;}
.contact-val{font-size:13px;color:var(–white);line-height:1.7;}
.contact-val a{color:var(–cyan);text-decoration:none;}

/* ── FLOAT BUTTONS ── */
.float-btns{
position:fixed;right:16px;bottom:calc(var(–bar-h) + 16px);
display:flex;flex-direction:column;gap:10px;z-index:150;
}
.float-btn{
width:50px;height:50px;border-radius:50%;
display:flex;align-items:center;justify-content:center;
font-size:20px;text-decoration:none;
box-shadow:0 4px 20px rgba(0,0,0,.4);
transition:transform .2s;
}
.float-btn:active{transform:scale(.92);}
.fb-phone{background:var(–blue);}
.fb-line{background:#06c755;}
.fb-chat{
background:var(–panel);border:1px solid var(–border);
cursor:pointer;
}
.fb-top{
background:rgba(255,255,255,0.08);border:1px solid var(–border);
cursor:pointer;color:var(–white);font-size:16px;
}

/* ── BOTTOM BAR ── */
.bottom-bar{
position:fixed;bottom:0;left:0;right:0;z-index:200;
height:var(–bar-h);display:flex;
}
.bar-btn{
flex:1;display:flex;align-items:center;justify-content:center;
font-family:‘Noto Sans TC’,sans-serif;font-size:14px;font-weight:500;
text-decoration:none;letter-spacing:1.5px;cursor:pointer;border:none;
transition:filter .2s;
}
.bar-btn:active{filter:brightness(1.15);}
.bar-call{background:linear-gradient(135deg,#0a84ff,#0060d0);color:#fff;}
.bar-line{background:linear-gradient(135deg,#06c755,#049a40);color:#fff;}

/* ── FOOTER ── */
footer{
padding:24px 20px;border-top:1px solid var(–border);
text-align:center;
font-family:‘Barlow Condensed’,sans-serif;font-size:10px;letter-spacing:2px;
color:var(–muted);text-transform:uppercase;line-height:2;
}

/* ── DIVIDER ── */
.div{height:1px;background:linear-gradient(to right,transparent,var(–border),transparent);margin:0 20px;}

/* ── REVEAL ── */
.rv{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease;}
.rv.vis{opacity:1;transform:translateY(0);}

/* ── CHAT TOOLTIP ── */
.chat-tip{
position:fixed;right:80px;bottom:calc(var(–bar-h) + 16px);
background:var(–panel);border:1px solid var(–border);
padding:8px 14px;font-size:12px;color:var(–muted);
white-space:nowrap;z-index:160;
opacity:0;pointer-events:none;transform:translateX(10px);
transition:all .3s;
}
.chat-tip.show{opacity:1;transform:translateX(0);}
</style>

</head>
<body>

<!-- NAV -->

<nav>
  <div class="nav-brand">
    <span class="nav-brand-cn">明曜晶光顯科技</span>
    <span class="nav-brand-en">MingYao Crystal Display</span>
  </div>
  <button class="hamburger" id="hmb" aria-label="選單">
    <span></span><span></span><span></span>
  </button>
</nav>

<!-- DRAWER -->

<div class="drawer" id="drawer">
  <ul class="drawer-menu">
    <li class="drawer-item">
      <button class="drawer-btn" onclick="toggleSub(this)">
        關於我們 <span class="icon">+</span>
      </button>
      <ul class="sub-menu">
        <li><a href="#about" onclick="closeDrawer()">公司簡介</a></li>
        <li><a href="#team" onclick="closeDrawer()">核心團隊</a></li>
      </ul>
    </li>
    <li class="drawer-item">
      <button class="drawer-btn" onclick="toggleSub(this)">
        業務範疇 <span class="icon">+</span>
