<script>
// Hamburger + Drawer
const hmb = document.getElementById('hmb');
const drawer = document.getElementById('drawer');
hmb.addEventListener('click', () => {
  const open = drawer.classList.toggle('open');
  hmb.classList.toggle('open', open);
  document.body.style.overflow = open ? 'hidden' : '';
});
function closeDrawer() {
  drawer.classList.remove('open');
  hmb.classList.remove('open');
  document.body.style.overflow = '';
}
function goTo(id) {
  closeDrawer();
  setTimeout(() => document.querySelector(id)?.scrollIntoView({behavior:'smooth'}), 300);
}

// Sub menu toggle
function toggleSub(btn) {
  const sub = btn.nextElementSibling;
  const isOpen = sub.classList.toggle('open');
  btn.classList.toggle('active', isOpen);
}

// Scroll reveal
const rv = new IntersectionObserver((entries) => {
  entries.forEach((e, i) => {
    if (e.isIntersecting) {
      setTimeout(() => e.target.classList.add('vis'), i * 60);
      rv.unobserve(e.target);
    }
  });
}, {threshold: 0.1});
document.querySelectorAll('.rv').forEach(el => rv.observe(el));

// Case search + filter
let activeTag = 'all';
function filterCases() {
  const q = document.getElementById('caseSearch').value.toLowerCase();
  document.querySelectorAll('.case-card').forEach(card => {
    const name = card.dataset.name.toLowerCase();
    const tag = card.dataset.tag;
    const matchQ = !q || name.includes(q);
    const matchT = activeTag === 'all' || tag === activeTag;
    card.style.display = (matchQ && matchT) ? '' : 'none';
  });
}
function filterByTag(tag, btn) {
  activeTag = tag;
  document.querySelectorAll('.case-tab').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  filterCases();
}

// Chat tooltip
function toggleChat() {
  const tip = document.getElementById('chatTip');
  tip.classList.toggle('show');
  if (tip.classList.contains('show')) {
    setTimeout(() => tip.classList.remove('show'), 3000);
  }
}

// Scroll to top on orb click
document.querySelector('.orb1').addEventListener('click', () => {
  window.scrollTo({top:0, behavior:'smooth'});
});
</script>

